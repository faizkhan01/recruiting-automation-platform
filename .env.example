NODE_ENV=development
API_PORT=4000
WEB_ORIGIN=http://localhost:5173
MONGODB_URI=mongodb://localhost:27017/recruiting_automation
REDIS_URL=redis://localhost:6379

# gemini | mock
AI_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# demo | serper
SOURCING_PROVIDER=demo
SERPER_API_KEY=

SCORE_CACHE_TTL_SECONDS=86400
TASK_RETENTION_DAYS=7

# Set to the number of trusted reverse-proxy hops in production (for example: 1).
TRUST_PROXY_HOPS=0

# Distributed inbound API limits (Redis-backed).
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=300
API_WRITE_RATE_LIMIT_MAX=80
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=12
EXTERNAL_SEARCH_RATE_LIMIT_WINDOW_MS=60000
EXTERNAL_SEARCH_RATE_LIMIT_MAX=20

# Provider retry safety boundaries.
PROVIDER_MAX_RETRY_DELAY_MS=60000
